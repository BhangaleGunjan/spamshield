# Server Configuration
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://mongo:27017/spamshield

# Redis
REDIS_URL=redis://redis:6379

# Google Safe Browsing API
# Get your key at: https://developers.google.com/safe-browsing/v4/get-started
GOOGLE_SAFE_BROWSING_API_KEY=your_api_key_here

# Sandbox Container Configuration
SANDBOX_API_URL=http://sandbox:3002
SANDBOX_SECRET=change_this_to_a_random_secret_string

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=50

# Analysis Timeouts
BROWSER_TIMEOUT_MS=15000
ANALYSIS_QUEUE_TIMEOUT_MS=30000

# Suspicious TLDs (comma-separated)
SUSPICIOUS_TLDS=.xyz,.tk,.ml,.ga,.cf,.gq,.top,.club,.work,.online
