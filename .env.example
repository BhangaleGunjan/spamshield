# Copy this to .env and fill in your values
# NEVER commit .env to git

# Shared secret between API and sandbox container
SANDBOX_SECRET=dev_local_secret_change_in_production

# Google Safe Browsing API key
# Get one free at: https://developers.google.com/safe-browsing/v4/get-started
# Leave blank to skip the check (still works, just no GSB data)
GOOGLE_SAFE_BROWSING_API_KEY=
